NEWS_API_KEY=
DISCOVERY_PROVIDER=newsapi
NEWS_REFRESH_TIMEOUT_MS=12000
NEWS_EXPANSION_SEED_COUNT=5
NEWS_MAX_SECTION_CLUSTERS=8
GOOGLE_NEWS_SEED_COUNT=8
NEWS_AUTO_REFRESH_MINUTES=2
NEWS_STALE_AFTER_MINUTES=4

# AI analysis. Set GEMINI_API_KEY in production.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=gemini
AI_TIMEOUT_MS=90000

# Public origins. Production values should use https.
FRONTEND_ORIGIN=http://127.0.0.1:5173
API_BASE_URL=http://127.0.0.1:3210
BACKEND_PUBLIC_URL=
VITE_API_BASE_URL=http://127.0.0.1:3210
CORS_ORIGINS=

# Auth. Google OAuth is the production sign-in path.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
SESSION_SECRET=
AUTH_HASH_SECRET=
SESSION_COOKIE_SAME_SITE=
EMAIL_CODE_AUTH_ENABLED=false

SERVE_STATIC=false
POSTGRES_DB=zelthir
POSTGRES_USER=zelthir
POSTGRES_PASSWORD=zelthir_dev_password
DATABASE_URL=postgres://zelthir:zelthir_dev_password@127.0.0.1:5432/zelthir
