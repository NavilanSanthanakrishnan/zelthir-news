{
  "name": "zelthir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server.mjs",
    "dev:frontend": "vite --host 127.0.0.1 --port 5173",
    "dev:backend": "node server.mjs",
    "dev:db": "docker compose up postgres",
