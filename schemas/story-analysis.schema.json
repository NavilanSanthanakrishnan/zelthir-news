{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "headline": { "type": "string" },
    "brief": { "type": "string" },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "article_paragraphs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 3,
      "maxItems": 6
    },
    "agreed_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "meta": { "type": "string" },
          "source_names": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 4
          }
        },
        "required": ["title", "meta", "source_names"],
        "additionalProperties": false
      },
      "maxItems": 4
    },
    "disputed_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "meta": { "type": "string" },
          "source_names": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 4
          }
        },
        "required": ["title", "meta", "source_names"],
        "additionalProperties": false
      },
      "maxItems": 3
    },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "percent": { "type": "integer", "minimum": 0, "maximum": 100 }
        },
        "required": ["label", "percent"],
        "additionalProperties": false
      },
      "maxItems": 4
    },
    "topic_map": {
      "type": "object",
      "properties": {
        "center": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "label": { "type": "string" },
            "summary": { "type": "string" }
          },
          "required": ["id", "label", "summary"],
          "additionalProperties": false
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "type": {
                "type": "string",
                "enum": [
                  "actor",
                  "place",
                  "policy",
                  "public_safety",
                  "economy",
                  "culture",
                  "sport",
                  "health",
                  "education",
                  "climate",
                  "technology",
                  "legal",
                  "community",
                  "unknown"
                ]
              },
              "summary": { "type": "string" },
              "weight": { "type": "integer", "minimum": 0, "maximum": 100 },
              "source_names": {
                "type": "array",
                "items": { "type": "string" },
                "maxItems": 4
              }
            },
            "required": ["id", "label", "type", "summary", "weight", "source_names"],
            "additionalProperties": false
          },
          "maxItems": 8
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "relationship": {
                "type": "string",
                "enum": [
                  "causes",
                  "responds_to",
                  "depends_on",
                  "escalates",
                  "constrains",
                  "funds",
                  "regulates",
                  "affects",
                  "contradicts",
                  "clarifies",
                  "related_to"
                ]
              },
              "summary": { "type": "string" },
              "support_count": { "type": "integer", "minimum": 0, "maximum": 12 }
            },
            "required": ["source", "target", "relationship", "summary", "support_count"],
            "additionalProperties": false
          },
          "maxItems": 12
        }
      },
      "required": ["center", "topics", "edges"],
      "additionalProperties": false
    },
    "watch_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "copy": { "type": "string" }
        },
        "required": ["title", "copy"],
        "additionalProperties": false
      },
      "maxItems": 4
    },
    "ripple_effects": {
      "type": "object",
      "properties": {
        "24h": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 4
        },
        "7d": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 4
        },
        "30d": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 4
        }
      },
      "required": ["24h", "7d", "30d"],
      "additionalProperties": false
    }
  },
  "required": [
    "headline",
    "brief",
    "confidence",
    "article_paragraphs",
    "agreed_claims",
    "disputed_claims",
    "frames",
    "topic_map",
    "watch_signals",
    "ripple_effects"
  ],
  "additionalProperties": false
}
